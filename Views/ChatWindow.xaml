<Window x:Class="Zexus.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zexus (Testing)"
        Width="1200" Height="750"
        MinWidth="480" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Topmost="False">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════════
             ZEXUS — GLASSMORPHISM
             Brand: #4285F4 Blue → #7B61FF Purple
             Base: #08090D cool black  |  Text: #E8EAED cool white
             ═══════════════════════════════════════════════════ -->

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="#E8EAED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EA4335"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="Foreground" Value="#E8EAED"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
            <Setter Property="CaretBrush" Value="#E8EAED"/>
            <Setter Property="SelectionBrush" Value="#4285F4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#404285F4"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send: gradient blue→purple with glow -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SendBorder" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4285F4" Offset="0"/>
                                    <GradientStop Color="#7B61FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.30" Color="#7B61FF"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SendBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5A95F5" Offset="0"/>
                                            <GradientStop Color="#9B85FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SendBorder" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="#4DFFFFFF"/>
                                <Setter TargetName="SendBorder" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#30FFFFFF" CornerRadius="2.5" Margin="1,0" Opacity="0.4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="5"/>
                    <Setter Property="MinHeight" Value="5"/>
                    <Setter Property="Width" Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- OUTER SHELL: gradient border + blue-purple ambient glow -->
    <Border x:Name="OuterShellBorder" CornerRadius="16" Padding="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="44" ShadowDepth="0" Opacity="0.10" Color="#7B61FF"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#204285F4" Offset="0"/>
                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                <GradientStop Color="#157B61FF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border x:Name="MainBgBorder" Background="#08090D" CornerRadius="15">
            <Grid>
                <!-- Ambient orbs: blue top-left, purple bottom-right -->
                <Canvas IsHitTestVisible="False" ClipToBounds="True">
                    <Ellipse Width="500" Height="500" Canvas.Left="-200" Canvas.Top="-200">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#084285F4" Offset="0"/>
                                <GradientStop Color="#004285F4" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="400" Height="400" Canvas.Right="-150" Canvas.Bottom="-150">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#067B61FF" Offset="0"/>
                                <GradientStop Color="#007B61FF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Center-right: subtle pink accent -->
                    <Ellipse Width="300" Height="300" Canvas.Right="-50" Canvas.Top="100">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#04D946EF" Offset="0"/>
                                <GradientStop Color="#00D946EF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE BAR -->
                    <Border x:Name="TitleBarBorder" Grid.Row="0" CornerRadius="15,15,0,0" Background="#0AFFFFFF"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="18,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="LogoImage" Width="20" Height="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Zexus" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E8EAED" VerticalAlignment="Center"
                                           FontFamily="Google Sans, Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="v0.2.0" FontSize="9" Foreground="#3DFFFFFF"
                                           VerticalAlignment="Center" Margin="8,2,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="ThemeToggleBtn" Content="☀" Click="OnToggleTheme" Style="{StaticResource HeaderButtonStyle}" Margin="2,0" ToolTip="Toggle Light/Dark mode" FontSize="14"/>
                                <Button x:Name="NewChatBtn" Content="New" Click="OnNewChat" Style="{StaticResource HeaderButtonStyle}" Margin="2,0" ToolTip="New conversation"/>
                                <Button x:Name="PinBtn" Content="Pin" Click="OnTogglePin" Style="{StaticResource HeaderButtonStyle}" Margin="2,0" ToolTip="Pin on top"/>
                                <Button x:Name="ExportLogBtn" Content="📄" Click="OnExportLog" Style="{StaticResource HeaderButtonStyle}" Margin="2,0" ToolTip="Export session report (AI facts pack)"/>
                                <Button x:Name="SettingsBtn" Content="⚙" Click="OnSettings" Style="{StaticResource HeaderButtonStyle}" Margin="2,0" ToolTip="Settings / API Key"/>
                                <Button Content="&#xE921;" Click="OnMinimize" Style="{StaticResource HeaderButtonStyle}" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="2,0" ToolTip="Minimize"/>
                                <Button x:Name="MaxRestoreBtn" Content="&#xE922;" Click="OnMaximizeRestore" Style="{StaticResource HeaderButtonStyle}" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="2,0" ToolTip="Maximize"/>
                                <Button Content="&#xE8BB;" Click="OnClose" Style="{StaticResource CloseButtonStyle}" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="2,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="DocLabelBar" Grid.Row="1" Background="#08FFFFFF" Padding="18,7">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DocumentLabel" Text="No document loaded"
                                       Foreground="#40FFFFFF" FontSize="11.5"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                            <TextBlock x:Name="ModelLocationSep" Text="  ·  "
                                       Foreground="#20FFFFFF" FontSize="11.5" Visibility="Collapsed"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                            <TextBlock x:Name="ModelLocationLabel" Text=""
                                       Foreground="#30FFFFFF" FontSize="11.5" Visibility="Collapsed"
                                       TextTrimming="CharacterEllipsis" MaxWidth="300"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                            <TextBlock x:Name="ModelHubSep" Text="  ·  "
                                       Foreground="#20FFFFFF" FontSize="11.5" Visibility="Collapsed"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                            <TextBlock x:Name="ModelHubLabel" Text=""
                                       Foreground="#30FFFFFF" FontSize="11.5" Visibility="Collapsed"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                        </StackPanel>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="360"/>
                            <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                            <ColumnDefinition x:Name="WorkspaceColumnDef" Width="0"/>
                            <ColumnDefinition x:Name="OutputSplitterColumn" Width="Auto"/>
                            <ColumnDefinition x:Name="OutputColumnDef" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0"
                                          VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="16,10,16,10">
                                <StackPanel x:Name="ChatContainer">
                                    <Border CornerRadius="16" Padding="24,20" Margin="32,16,32,16"
                                            HorizontalAlignment="Center" BorderThickness="1" BorderBrush="#12FFFFFF">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0EFFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel HorizontalAlignment="Center">
                                            <!-- Gradient accent bar -->
                                            <Border Width="32" Height="3" CornerRadius="1.5" HorizontalAlignment="Center" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#4285F4" Offset="0"/>
                                                        <GradientStop Color="#7B61FF" Offset="0.5"/>
                                                        <GradientStop Color="#D946EF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="Welcome to Zexus" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="#E8EAED" TextAlignment="Center" Margin="0,0,0,2"
                                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                            <TextBlock Text="v0.2.0" FontSize="9" FontWeight="SemiBold" TextAlignment="Center"
                                                       Foreground="#7B61FF" Margin="0,0,0,10"
                                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                            <TextBlock TextWrapping="Wrap" Foreground="#50FFFFFF" FontSize="12" TextAlignment="Left" LineHeight="20"
                                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji">
                                                Describe what you need in plain language — the AI agent writes and executes Revit API code to accomplish it.
                                            </TextBlock>
                                            <Border CornerRadius="6" Background="#08FFFFFF" Padding="12,8" Margin="0,10,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="#40FFFFFF" FontSize="11" LineHeight="18"
                                                           FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji">
                                                    ⚡ Try: "Check all doors — find missing Fire Rating values and list by level" · "Duplicate this floor plan as dependent views for each Segment scope box" · "Create a door schedule, add Mark / Level / Fire Rating, sort by level"
                                                </TextBlock>
                                            </Border>
                                            <Border CornerRadius="6" Background="#0A7B61FF" Padding="12,8" Margin="0,8,0,0"
                                                    BorderBrush="#157B61FF" BorderThickness="1">
                                                <TextBlock TextWrapping="Wrap" Foreground="#50FFFFFF" FontSize="10.5" LineHeight="16"
                                                           FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji">
                                                    ⚠ No project standards loaded yet. Provide your BIM standards to the developer for integration. Session reports auto-export — your usage data shapes future development.
                                                </TextBlock>
                                            </Border>
                                            <!-- Model Briefing (populated on document load — zero token cost) -->
                                            <StackPanel x:Name="WelcomeBriefingPanel" Margin="0,14,0,0" Visibility="Collapsed">
                                                <!-- Discipline -->
                                                <Border x:Name="BriefingDisciplineSection" CornerRadius="6" Background="#08FFFFFF" Padding="12,8" Margin="0,0,0,6" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock x:Name="BriefingDisciplineLabel" Text="" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#90FFFFFF" FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                                        <TextBlock x:Name="BriefingTopCategories" Text="" FontSize="10.5" TextWrapping="Wrap"
                                                                   Foreground="#40FFFFFF" Margin="0,3,0,0" LineHeight="16"
                                                                   FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Stats -->
                                                <Border CornerRadius="6" Background="#08FFFFFF" Padding="12,8" Margin="0,0,0,6">
                                                    <TextBlock x:Name="BriefingStatsLine" Text="" FontSize="11" TextWrapping="Wrap"
                                                               Foreground="#50FFFFFF" LineHeight="16"
                                                               FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                                </Border>
                                                <!-- Health (clickable → expands to show warning groups) -->
                                                <Border x:Name="BriefingHealthSection" CornerRadius="6" Padding="12,8" Margin="0,0,0,6"
                                                        Visibility="Collapsed" Cursor="Hand">
                                                    <StackPanel>
                                                        <!-- Header row (always visible) -->
                                                        <StackPanel x:Name="BriefingHealthHeader" Orientation="Horizontal">
                                                            <Border x:Name="BriefingHealthDot" Width="8" Height="8" CornerRadius="4"
                                                                    VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock x:Name="BriefingHealthText" Text="" FontSize="11"
                                                                       Foreground="#50FFFFFF" VerticalAlignment="Center"
                                                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                                            <TextBlock x:Name="BriefingHealthChevron" Text="▸" FontSize="10"
                                                                       Foreground="#30FFFFFF" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       FontFamily="Segoe UI"/>
                                                        </StackPanel>
                                                        <!-- Expandable warning group list (hidden by default) -->
                                                        <StackPanel x:Name="BriefingWarningGroupList" Margin="0,8,0,0" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Suggestions -->
                                                <Border x:Name="BriefingSuggestionsSection" CornerRadius="6" Background="#0A7B61FF"
                                                        Padding="12,8" Margin="0,0,0,0" BorderBrush="#107B61FF" BorderThickness="1"
                                                        Visibility="Collapsed">
                                                    <StackPanel x:Name="BriefingSuggestionsContainer"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Status: blue pulse dot with breathing animation -->
                            <Border x:Name="StatusBar" Grid.Row="1" Background="#0AFFFFFF" Padding="18,8" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="StatusDot" Width="6" Height="6" CornerRadius="3" Background="#4285F4" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="StatusDotGlow" BlurRadius="8" ShadowDepth="0" Opacity="0.6" Color="#4285F4"/>
                                        </Border.Effect>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Border.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <!-- Dot opacity: 1.0 → 0.35 -->
                                                        <DoubleAnimation Storyboard.TargetName="StatusDot"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.35"
                                                                         Duration="0:0:1.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <!-- Glow blur: 8 → 14 -->
                                                        <DoubleAnimation Storyboard.TargetName="StatusDotGlow"
                                                                         Storyboard.TargetProperty="BlurRadius"
                                                                         From="8" To="14"
                                                                         Duration="0:0:1.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <TextBlock x:Name="StatusText" Text="Processing..." Foreground="#60FFFFFF" FontSize="12"
                                               FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <GridSplitter x:Name="WorkspaceSplitter" Grid.Column="1" Width="1" Background="#15FFFFFF"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" Visibility="Collapsed"/>

                        <Border x:Name="WorkspacePanel" Grid.Column="2" Background="#06FFFFFF"
                                BorderBrush="#0AFFFFFF" BorderThickness="1,0,0,0" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                                <StackPanel x:Name="WorkspaceContainer"/>
                            </ScrollViewer>
                        </Border>

                        <GridSplitter x:Name="OutputSplitter" Grid.Column="3" Width="1" Background="#15FFFFFF"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" Visibility="Collapsed"/>

                        <Border x:Name="OutputPanel" Grid.Column="4" Background="#06FFFFFF"
                                BorderBrush="#0AFFFFFF" BorderThickness="1,0,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="OutputScrollViewer" VerticalScrollBarVisibility="Auto" Padding="14,10">
                                <StackPanel x:Name="OutputContainer"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- SELECTION INSPECTOR (above input bar) -->
                    <Border x:Name="SelectionInspectorBar" Grid.Row="3"
                            Background="#06FFFFFF" Padding="18,5" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3" VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4285F4" Offset="0"/>
                                        <GradientStop Color="#7B61FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="SelectionInfoText" Text=""
                                       Foreground="#50FFFFFF" FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="Google Sans, Segoe UI Variable, Segoe UI, Segoe UI Emoji"/>
                        </StackPanel>
                    </Border>

                    <!-- IMAGE PREVIEW BAR (auto-hidden when empty; populated by paste handler) -->
                    <Border x:Name="ImagePreviewBar" Grid.Row="4" Visibility="Collapsed"
                            Padding="8,6" Background="#08FFFFFF">
                        <StackPanel x:Name="ImagePreviewPanel" Orientation="Horizontal"/>
                    </Border>

                    <!-- INPUT BAR -->
                    <Border x:Name="InputBarBorder" Grid.Row="5" CornerRadius="0,0,15,15" Padding="14,10,14,14" Background="#0AFFFFFF">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness><Thickness Top="1"/></Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MessageInput" Grid.Column="0" AcceptsReturn="True" TextWrapping="Wrap"
                                     MaxHeight="100" VerticalScrollBarVisibility="Auto" KeyDown="OnInputKeyDown"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                            <Button x:Name="SendBtn" Grid.Column="1" Content="↑" Click="OnSend" FontWeight="Bold"
                                    Style="{StaticResource SendButtonStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
